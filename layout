<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>个人简历</title>
    <!-- Font Awesome 6 免费图标库 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Roboto', 'Inter', system-ui, -apple-system, 'Helvetica Neue', sans-serif;
            background: #eef2f7;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            color: #1e293b;
        }

        /* 主布局：全屏flex */
        .app {
            display: flex;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        /* ========= 左侧边栏 (照片+个人信息+动态目录) ========= */
        .sidebar {
            width: 290px;
            background: linear-gradient(145deg, #122031 0%, #0a111c 100%);
            color: #e0edf9;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.12);
            overflow-y: auto;
            flex-shrink: 0;
            z-index: 10;
            transition: all 0.2s;
        }

        .sidebar::-webkit-scrollbar {
            width: 5px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: #0f1724;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: #3b6e9e;
            border-radius: 8px;
        }

        /* 头像区域 */
        .photo-area {
            text-align: center;
            margin: 2rem 1.5rem 0.5rem 1.5rem;
        }
        .avatar-frame {
            width: 130px;
            height: 130px;
            margin: 0 auto;
            border-radius: 50%;
            background: #2c4058;
            border: 3px solid rgba(100, 181, 246, 0.7);
            overflow: hidden;
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.2);
            transition: transform 0.2s;
        }
        .avatar-frame:hover {
            transform: scale(1.02);
        }
        .avatar-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .avatar-placeholder {
            background: #2c5368;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            font-size: 3.5rem;
            color: #cae3ff;
        }

        .basic-info {
            padding: 0.8rem 1.5rem 1rem 1.5rem;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 1rem;
        }
        .basic-info h1 {
            font-size: 1.7rem;
            font-weight: 600;
            margin: 0.3rem 0 0.2rem;
            color: white;
        }
        .basic-info .tagline {
            font-size: 0.85rem;
            color: #9cb8dc;
            margin-bottom: 0.7rem;
        }
        .contact-list {
            font-size: 0.75rem;
            text-align: left;
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 0.8rem;
            margin-top: 0.5rem;
        }
        .contact-list p {
            margin: 0.45rem 0;
            display: flex;
            align-items: center;
            gap: 10px;
            word-break: break-all;
        }
        .contact-list i {
            width: 22px;
            color: #7aa9dd;
        }

        /* 左侧动态目录导航 (仅个人简历页面显示完整目录，其他页面显示相应提示) */
        .nav-dynamic {
            padding: 1rem 1rem 2rem 1rem;
            flex: 1;
        }
        .nav-header {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            color: #8196ae;
            margin: 0.2rem 0 0.8rem 0.7rem;
        }
        .nav-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.7rem 1rem;
            border-radius: 40px;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
            color: #cbdbe6;
        }
        .nav-item i {
            width: 24px;
            font-size: 1.1rem;
            text-align: center;
        }
        .nav-item:hover {
            background: rgba(255, 255, 255, 0.12);
            color: white;
            transform: translateX(5px);
        }
        .nav-item.active-nav {
            background: #2c6e9e;
            color: white;
            box-shadow: 0 4px 10px rgba(44, 110, 158, 0.3);
        }
        .page-placeholder-nav {
            padding: 1rem;
            font-size: 0.85rem;
            background: rgba(255,255,255,0.03);
            border-radius: 20px;
            text-align: center;
            margin-top: 1rem;
            color: #9aaec9;
        }

        /* ========= 右侧主区域 ========= */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: #f6f9fe;
        }

        /* 上方页面切换栏 (满足上方边栏切换不同page) */
        .page-toolbar {
            background: white;
            padding: 0.7rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #e2edf2;
            box-shadow: 0 1px 4px rgba(0,0,0,0.02);
            flex-wrap: wrap;
            gap: 10px;
        }
        .page-switcher {
            display: flex;
            gap: 12px;
            background: #f0f4f9;
            padding: 5px;
            border-radius: 60px;
        }
        .page-btn {
            background: transparent;
            border: none;
            padding: 0.5rem 1.5rem;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s;
            font-family: inherit;
            color: #2c3e58;
        }
        .page-btn i {
            margin-right: 8px;
        }
        .page-btn.active-page {
            background: #2c6e9e;
            color: white;
            box-shadow: 0 2px 8px rgba(44,110,158,0.25);
        }
        .page-btn:hover:not(.active-page) {
            background: #e2e8f0;
        }

        /* 滚动内容容器 */
        .pages-container {
            flex: 1;
            overflow-y: auto;
            padding: 2rem 2rem 2rem 2rem;
            scroll-behavior: smooth;
        }
        /* 每个大页面容器 */
        .page-panel {
            display: none;
            animation: fade 0.25s ease;
        }
        .page-panel.active-page-panel {
            display: block;
        }
        @keyframes fade {
            from { opacity: 0; transform: translateY(8px);}
            to { opacity: 1; transform: translateY(0);}
        }

        /* 简历卡片 & 区块样式 (个人简历页面) */
        .resume-section {
            background: white;
            border-radius: 32px;
            padding: 1.5rem 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.02), 0 2px 4px rgba(0,0,0,0.02);
            border: 1px solid #eef2f8;
            scroll-margin-top: 20px;
        }
        .section-title {
            font-size: 1.7rem;
            font-weight: 700;
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 5px solid #2c6e9e;
            padding-left: 1rem;
            color: #0f2b3d;
        }
        .section-title i {
            color: #2c6e9e;
            font-size: 1.6rem;
        }
        .timeline-item {
            margin-bottom: 1.6rem;
            border-left: 2px solid #cbdde9;
            padding-left: 1.2rem;
        }
        .timeline-item h3 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 0.2rem;
        }
        .date-badge {
            font-size: 0.75rem;
            background: #eaf3ff;
            display: inline-block;
            padding: 0.2rem 0.9rem;
            border-radius: 40px;
            margin: 0.4rem 0 0.6rem;
            color: #2c5282;
        }
        .desc-list {
            padding-left: 1.2rem;
            color: #2d3e5a;
            line-height: 1.5;
            margin-top: 0.4rem;
        }
        .desc-list li {
            margin: 0.5rem 0;
        }
        .skills-tag {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 1rem;
        }
        .skill-tag {
            background: #eef2ff;
            padding: 0.3rem 1rem;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #1f5090;
        }
        .strength-grid {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .strength-card {
            background: #fafdff;
            padding: 1rem 1.2rem;
            border-radius: 24px;
            display: flex;
            align-items: center;
            gap: 1rem;
            border: 1px solid #e6edf4;
        }
        .strength-icon {
            width: 48px;
            height: 48px;
            background: #eaf1fc;
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #2c6e9e;
        }

        /* 游戏经历 & 作品集页面卡片 */
        .custom-page-card {
            background: white;
            border-radius: 32px;
            padding: 2rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        }
        .game-item, .portfolio-item {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #eef2fa;
        }
        .game-item h3, .portfolio-item h3 {
            font-size: 1.2rem;
            margin-bottom: 6px;
        }

        footer {
            text-align: center;
            font-size: 0.7rem;
            color: #7f8c9a;
            margin-top: 1.5rem;
            padding-top: 0.5rem;
        }

        @media (max-width: 760px) {
            .sidebar { width: 250px; }
            .pages-container { padding: 1rem; }
            .resume-section { padding: 1rem; }
            .page-btn { padding: 0.3rem 1rem; font-size: 0.8rem;}
        }
        @media (max-width: 600px) {
            .app { flex-direction: column; }
            .sidebar { width: 100%; max-height: 280px; flex-direction: row; flex-wrap: wrap; overflow-y: auto; }
            .photo-area { margin: 0.5rem; }
            .basic-info { border-bottom: none; }
            .nav-dynamic { padding: 0.5rem; }
            .nav-list { flex-direction: row; flex-wrap: wrap; }
            .nav-item { padding: 0.3rem 0.9rem; }
        }

        .highlight {
            transition: all 0.2s;
        }
        .back2top {
            position: fixed;
            bottom: 25px;
            right: 25px;
            background: #2c6e9e;
            color: white;
            border-radius: 40px;
            padding: 8px 14px;
            font-size: 0.8rem;
            cursor: pointer;
            box-shadow: 0 2px 12px rgba(0,0,0,0.2);
            z-index: 99;
            display: none;
        }
    </style>
</head>
