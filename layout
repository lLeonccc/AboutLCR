<script>
    (function() {
        // 获取元素
        const pageBtns = document.querySelectorAll('.page-btn');
        const pages = {
            resume: document.getElementById('page-resume'),
            games: document.getElementById('page-games'),
            portfolio: document.getElementById('page-portfolio')
        };
        const container = document.getElementById('pagesContainer');
        const dynamicNavDiv = document.getElementById('dynamicNav');
        const backTop = document.getElementById('back2top');

        // 当前激活的大页面
        let currentPage = 'resume';   // 'resume', 'games', 'portfolio'

        // ---------- 渲染左侧动态导航 (根据当前页面渲染) ----------
        function renderSidebarNav() {
            if (currentPage === 'resume') {
                // 个人简历页面：展示章节目录导航 (教育经历、校园经历、项目经历、个人优势)
                const sections = [
                    { id: 'resume-education', name: '教育经历', icon: 'fas fa-graduation-cap' },
                    { id: 'resume-campus', name: '校园经历', icon: 'fas fa-users' },
                    { id: 'resume-project', name: '项目经历', icon: 'fas fa-code-branch' },
                    { id: 'resume-strength', name: '个人优势', icon: 'fas fa-chart-line' }
                ];
                let navHtml = `<div class="nav-header"><i class="fas fa-compass"></i> 目录导航</div><div class="nav-list" id="resumeNavList">`;
                sections.forEach(section => {
                    navHtml += `<div class="nav-item" data-nav-section="${section.id}">
                                    <i class="${section.icon}"></i> <span>${section.name}</span>
                                </div>`;
                });
                dynamicNavDiv.innerHTML = navHtml;
                // 绑定滚动导航点击事件
                const navItemsDynamic = document.querySelectorAll('#resumeNavList .nav-item');
                navItemsDynamic.forEach(item => {
                    item.addEventListener('click', (e) => {
                        const targetId = item.getAttribute('data-nav-section');
                        if (targetId) {
                            const targetElem = document.getElementById(targetId);
                            if (targetElem) {
                                targetElem.scrollIntoView({ behavior: 'smooth', block: 'start' });
                                // 高亮当前点击
                                navItemsDynamic.forEach(nav => nav.classList.remove('active-nav'));
                                item.classList.add('active-nav');
                                // 滚动后，通过监听scroll更新高亮也可，先简单处理
                            }
                        }
                    });
                });
                // 监听滚动自动高亮当前可见区域 (增强体验)
                attachScrollSpy();
            } 
            else if (currentPage === 'games') {
                dynamicNavDiv.innerHTML = `<div class="nav-header"><i class="fas fa-gamepad"></i> 游戏·导航</div>
                <div class="page-placeholder-nav"><i class="fas fa-info-circle"></i> 当前为「游戏经历」页面<br>您可以自由补充作品与项目</div>
                <div style="margin-top: 15px;"><div class="nav-item" id="fakeGameGuide" style="cursor:default; opacity:0.7;"><i class="fas fa-trophy"></i> 游戏开发履历</div></div>`;
            } 
            else if (currentPage === 'portfolio') {
                dynamicNavDiv.innerHTML = `<div class="nav-header"><i class="fas fa-folder-open"></i> 作品集·导览</div>
                <div class="page-placeholder-nav"><i class="fas fa-paintbrush"></i> 展示个人创意项目<br>左侧目录仅为示意，无锚点导航</div>
                <div style="margin-top: 8px;"><div class="nav-item" style="cursor:default;"><i class="fas fa-star"></i> 全栈/设计作品</div></div>`;
            }
            // 清除现有滚动监听重新绑定（避免多次）
            if (window._scrollHandler) container.removeEventListener('scroll', window._scrollHandler);
        }

        // 滚动时高亮当前可见的简历区块 (仅个人简历页面使用)
        let scrollHandler = null;
        function attachScrollSpy() {
            if (scrollHandler) container.removeEventListener('scroll', scrollHandler);
            const sectionsArr = ['resume-education', 'resume-campus', 'resume-project', 'resume-strength'];
            const navItemsSelector = '#resumeNavList .nav-item';
            const getNavItems = () => document.querySelectorAll(navItemsSelector);
            function updateActiveSection() {
                if (currentPage !== 'resume') return;
                const navItems = getNavItems();
                if (!navItems.length) return;
                let currentActiveId = null;
                // 获取每个section的位置
                for (let id of sectionsArr) {
                    const elem = document.getElementById(id);
                    if (elem) {
                        const rect = elem.getBoundingClientRect();
                        const containerRect = container.getBoundingClientRect();
                        // 如果元素顶部在可视区域上方且底部超过一定阈值
                        if (rect.top <= containerRect.top + 100 && rect.bottom >= containerRect.top + 50) {
                            currentActiveId = id;
                            break;
                        }
                    }
                }
                // 如果没有匹配，取第一个在视口上方的最后一项
                if (!currentActiveId) {
                    for (let id of sectionsArr.slice().reverse()) {
                        const elem = document.getElementById(id);
                        if (elem && elem.getBoundingClientRect().top < container.getBoundingClientRect().top + 80) {
                            currentActiveId = id;
                            break;
                        }
                    }
                }
                navItems.forEach(item => {
                    const targetSec = item.getAttribute('data-nav-section');
                    if (targetSec === currentActiveId) {
                        item.classList.add('active-nav');
                    } else {
                        item.classList.remove('active-nav');
                    }
                });
            }
            scrollHandler = () => { updateActiveSection(); };
            container.addEventListener('scroll', scrollHandler);
            updateActiveSection(); // 立即执行一次
        }

        // 切换大页面的方法
        function switchPage(pageId) {
            if (!pages[pageId]) return;
            // 更新页面面板显示
            Object.keys(pages).forEach(pid => {
                pages[pid].classList.remove('active-page-panel');
            });
            pages[pageId].classList.add('active-page-panel');
            // 更新按钮样式
            pageBtns.forEach(btn => {
                if (btn.getAttribute('data-page') === pageId) {
                    btn.classList.add('active-page');
                } else {
                    btn.classList.remove('active-page');
                }
            });
            currentPage = pageId;
            // 重新渲染左侧导航
            renderSidebarNav();
            // 滚动容器回到顶部
            container.scrollTo({ top: 0, behavior: 'smooth' });
            // 如果切换回个人简历页面，确保滚动监听和nav高亮可用
            if (pageId === 'resume') {
                setTimeout(() => {
                    attachScrollSpy();
                }, 100);
            } else {
                if (scrollHandler) container.removeEventListener('scroll', scrollHandler);
            }
        }

        // 绑定顶部切换按钮
        pageBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const page = btn.getAttribute('data-page');
                if (page) switchPage(page);
            });
        });

        // 回到顶部
        backTop.addEventListener('click', () => {
            container.scrollTo({ top: 0, behavior: 'smooth' });
        });
        window.addEventListener('scroll', () => {
            if (container.scrollTop > 400) backTop.style.display = 'flex';
            else backTop.style.display = 'none';
        });
        container.addEventListener('scroll', () => {
            if (container.scrollTop > 400) backTop.style.display = 'flex';
            else backTop.style.display = 'none';
        });
        backTop.style.display = 'none';
        backTop.style.alignItems = 'center';
        backTop.style.gap = '6px';

        // 初始化
        switchPage('resume');
    })();
</script>
</body>
</html>
